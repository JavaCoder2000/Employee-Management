.admin-layout {
  display: flex;
  min-height: 100vh;
  background: #f8fafc;
}

.admin-main {
  width: 100%;
  margin-left: 270px;
  background: #f8fafc;
  min-height: 100vh;
  flex: 1;
  padding: 20px;
  transition: 0.3s;
  overflow-x: hidden;
   width: calc(100% - 270px);
}

.dashboard-content {
  padding: 30px;
}

.dashboard-cards {
  display: grid;

  grid-template-columns:
repeat(auto-fit,minmax(250px,1fr));

  gap: 24px;

  margin-bottom: 30px;
}

.dashboard-card {
  background: white;

  border-radius: 28px;

  padding: 28px;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.05);
}

.dashboard-card p {
  color: #64748b;
}

.dashboard-card h2 {
  margin-top: 14px;

  font-size: 40px;

  color: #0f172a;
}

.employee-table-box {
  background: white;

  border-radius: 28px;

  padding: 28px;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.05);
}

.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 24px;
}

.table-header button {
  border: none;

  padding: 14px 18px;

  border-radius: 14px;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  color: white;

  cursor: pointer;
}

.table-wrapper {
  width: 100%;
  overflow-x: auto;
}

table {
  width: 100%;

  border-collapse: collapse;
}

th,
td {
  text-align: left;

  padding: 18px;
}

th {
  color: #64748b;
}

tr {
  border-bottom:
    1px solid #e2e8f0;
}

.active-status {
  background: #dcfce7;

  color: #15803d;

  padding: 8px 12px;

  border-radius: 30px;

  font-size: 13px;
}

@media(max-width:768px) {

  .admin-main {
    margin-left: 0;
    width: 100%;
    padding: 85px 15px 20px;
  }
  .dashboard-content {
    padding: 20px;
  }

}