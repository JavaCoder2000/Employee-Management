.attendance-modal {
  width: 100%;
  max-width: 500px;

  background: white;

  border-radius: 28px;

  padding: 30px;

  margin: 20px;
}

.attendance-modal h2 {
  margin-bottom: 24px;
}

.attendance-modal form {
  display: flex;
  flex-direction: column;

  gap: 18px;
}

.attendance-modal input,
.attendance-modal select {
  border:
    1px solid #e2e8f0;

  padding: 16px;

  border-radius: 16px;

  outline: none;
}

.modal-actions {
  display: flex;

  gap: 14px;

  margin-top: 10px;
}

.modal-actions button {
  flex: 1;

  border: none;

  padding: 16px;

  border-radius: 16px;

  cursor: pointer;
}

.modal-actions button:first-child {
  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  color: white;
}

.cancel-btn {
  background: #f1f5f9;
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(6px);

  display: flex;
  justify-content: center;
  align-items: center;

  padding: 20px;
  z-index: 9999;

  overflow-y: auto; /* IMPORTANT */
}

.attendance-modal {
  width: 100%;
  max-width: 500px;

  background: white;

  border-radius: 28px;

  padding: 30px;

  margin: auto;

  max-height: 92vh; /* IMPORTANT */
  overflow-y: auto; /* IMPORTANT */

  animation: modalSlide 0.3s ease;
}

/* SCROLLBAR */

.attendance-modal::-webkit-scrollbar {
  width: 8px;
}

.attendance-modal::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 20px;
}

.attendance-modal h2 {
  margin-bottom: 24px;
  font-size: 28px;
  color: #0f172a;
}

.attendance-modal form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.attendance-modal input,
.attendance-modal select {
  border: 1px solid #e2e8f0;

  padding: 16px;

  border-radius: 16px;

  outline: none;

  background: #f8fafc;

  transition: 0.3s;
}

.attendance-modal input:focus,
.attendance-modal select:focus {
  border-color: #2563eb;
  background: white;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

.modal-actions {
  display: flex;

  gap: 14px;

  margin-top: 10px;
}

.modal-actions button {
  flex: 1;

  border: none;

  padding: 16px;

  border-radius: 16px;

  cursor: pointer;

  font-weight: 600;

  transition: 0.3s;
}

.modal-actions button:first-child {
  background: linear-gradient(
    135deg,
    #2563eb,
    #4f46e5
  );

  color: white;
}

.cancel-btn {
  background: #f1f5f9;
}

.modal-actions button:hover {
  transform: translateY(-2px);
}

/* MOBILE */

@media (max-width: 768px) {
  .attendance-modal {
    padding: 22px;
    border-radius: 22px;
    max-height: 95vh;
  }

  .modal-actions {
    flex-direction: column;
  }
}

/* ANIMATION */

@keyframes modalSlide {
  from {
    opacity: 0;
    transform: translateY(40px) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}