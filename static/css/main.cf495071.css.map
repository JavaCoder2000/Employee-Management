.topbar {
  background: white;

  padding: 24px 30px;

  display: flex;
  justify-content: space-between;
  align-items: center;

  box-shadow:
    0 4px 20px rgba(0,0,0,0.04);

    border-radius: 15px;
}

.topbar h1 {
  color: #0f172a;
}

.topbar p {
  color: #64748b;

  margin-top: 4px;
}

.topbar-profile {
  display: flex;
  align-items: center;
  gap: 14px;
}

.topbar-profile img {
  width: 52px;
  height: 52px;

  border-radius: 50%;
}

@media (max-width: 768px) {

  .topbar {
    align-items: center;
    justify-content: center;
    text-align: center;
    flex-direction: column; 
  }

  .topbar-left {
    display: none;
  }

  .topbar h1 {
    font-size: 22px;
  }

}