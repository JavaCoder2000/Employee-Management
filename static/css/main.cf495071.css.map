.sidebar {
  width: 280px;
  height: 100vh;

  background: linear-gradient(
    180deg,
    #3a4e7e,
    #111827
  );

  position: fixed;
  left: 0;
  top: 0;

  padding: 30px 20px;

  overflow-y: auto;

  transition: 0.3s ease;

  z-index: 1000;

  border-radius: 0 30px 30px 0;
}

.logo {
  color: white;
  font-size: 28px;
  margin-bottom: 40px;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 14px;

  padding: 16px;

  border-radius: 16px;

  text-decoration: none;

  color: #cbd5e1;

  margin-bottom: 12px;

  transition: 0.3s;
}

.sidebar-link:hover {
  background: rgba(255,255,255,0.08);
  color: white;
}

.logout-btn {
  width: 100%;

  margin-top: 30px;

  padding: 16px;

  border: none;

  border-radius: 16px;

  background: #ef4444;

  color: white;

  cursor: pointer;
}

/* HAMBURGER */

.menu-btn {
  display: none;
}

.overlay {
  display: none;
}

/* MOBILE */

@media(max-width:768px) {

   .menu-btn {
    display: flex;

    position: fixed;

    top: 18px;
    left: 18px;

    width: 52px;
    height: 52px;

    border: none;

    border-radius: 14px;

    background: #2563eb;

    color: white;

    justify-content: center;
    align-items: center;

    font-size: 24px;

    z-index: 1200;

    cursor: pointer;
  }

  .sidebar {
    left: -100%;
    width: 260px;
  }

  .sidebar.active {
    left: 0;
  }

  .overlay {
    display: block;

    position: fixed;

    inset: 0;

    background: rgba(0,0,0,0.5);

    z-index: 999;
  }

}

.button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 15px 20px;
  background-color: #212121;
  border: none;
  font: inherit;
  color: #e8e8e8;
  font-size: 20px;
  font-weight: 600;
  border-radius: 50px;
  cursor: not-allowed;
  overflow: hidden;
  transition: all 0.3s ease cubic-bezier(0.23, 1, 0.320, 1);
}

.button span {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.button::before {
  position: absolute;
  content: '';
  width: 100%;
  height: 100%;
  translate: 0 105%;
  background-color: #F53844;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.button svg {
  width: 32px;
  height: 32px;
  fill: #F53844;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.button:hover {
  animation: shake 0.2s linear 1;
}

.button:hover::before {
  translate: 0 0;
}

.button:hover svg {
  fill: #e8e8e8;
}

@keyframes shake {
  0% {
    rotate: 0deg;
  }

  33% {
    rotate: 10deg;
  }

  66% {
    rotate: -10deg;
  }

  100% {
    rotate: 10deg;
  }
}
