.admin-sidebar {
  width: 270px;
  height: 100vh;
  background:
    linear-gradient(
      180deg,
      #0f172a,
      #111827
    );
  position: fixed;
  left: 0;
  top: 0;
  padding: 30px 20px;
  overflow-y: auto;
  z-index: 1000;
  transition: 0.3s ease;
}

.admin-logo {
  color: white;

  margin-bottom: 40px;

  font-size: 30px;
}

.admin-link {
  display: flex;
  align-items: center;
  gap: 14px;

  padding: 16px;

  border-radius: 16px;

  color: #cbd5e1;

  text-decoration: none;

  margin-bottom: 12px;

  transition: 0.3s ease;
}

.admin-link:hover {
  background: rgba(255,255,255,0.08);

  color: white;
}

.admin-logout-btn {
  width: 100%;

  margin-top: 30px;

  border: none;

  padding: 16px;

  border-radius: 16px;

  background: #ef4444;

  color: white;

  cursor: pointer;

  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
}

/* MOBILE */

.admin-menu-btn {
  display: none;
}

.admin-overlay {
  display: none;
}

@media(max-width:768px) {

  .admin-menu-btn {
    display: flex;

    position: fixed;

    top: 18px;
    left: 18px;

    width: 52px;
    height: 52px;

    border: none;

    border-radius: 14px;

    background: #2563eb;

    color: white;

    justify-content: center;
    align-items: center;

    font-size: 24px;

    z-index: 1200;
  }

  .admin-sidebar{
    left: -100%;
    transform: translateX(-100%);
    transition: 0.3s;
  }

  .admin-sidebar.active{
    left: 0;
    transform: translateX(0);
  }

  .admin-overlay {
    display: block;

    position: fixed;

    inset: 0;

    background: rgba(0,0,0,0.5);

    z-index: 999;
  }

}