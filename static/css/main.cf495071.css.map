.docs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
}

.docs-header h1 {
  font-size: 34px;
  color: #111827;
}

.docs-header p {
  color: #6b7280;
  margin-top: 8px;
}

.docs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
}

.doc-card {
  background: white;
  border-radius: 24px;
  padding: 25px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  transition: 0.3s ease;
}

.doc-card:hover {
  transform: translateY(-6px);
}

.doc-top {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 25px;
}

.doc-icon {
  font-size: 34px;
  color: #2563eb;
}

.doc-top h3 {
  color: #111827;
}

.doc-actions {
  display: flex;
  gap: 15px;
}

.view-btn,
.download-btn {
  flex: 1;
  border: none;
  text-decoration: none;
  padding: 12px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-weight: 600;
  transition: 0.3s ease;
}

.view-btn {
  background: #eff6ff;
  color: #2563eb;
}

.download-btn {
  background: linear-gradient(
    135deg,
    #2563eb,
    #4f46e5
  );
  color: white;
}

.view-btn:hover,
.download-btn:hover {
  transform: scale(1.03);
}

.loading-box,
.empty-docs {
  min-height: 300px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #6b7280;
}

.empty-docs svg {
  font-size: 70px;
  margin-bottom: 20px;
  color: #2563eb;
}

@media (max-width: 768px) {
  .docs-grid {
    grid-template-columns: 1fr;
  }

  .doc-actions {
    flex-direction: column;
  }
}