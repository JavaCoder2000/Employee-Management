.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  padding: 20px;
  animation: fadeIn 0.3s ease;
}

.employee-modal {
  position: relative;
  margin: auto;
}

.modern-modal {
  width: 100%;
  max-width: 900px;
  max-height: 92vh;
  overflow-y: auto;
  background: white;
  border-radius: 30px;
  padding: 35px;
  animation: slideUp 0.35s ease;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

/* SCROLLBAR */

.modern-modal::-webkit-scrollbar {
  width: 8px;
}

.modern-modal::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 20px;
}

.modern-modal h2 {
  font-size: 32px;
  margin-bottom: 30px;
  color: #0f172a;
}

/* FORM GRID */

.modern-modal form {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

/* INPUTS */

.modern-modal input,
.modern-modal select {
  width: 100%;
  padding: 15px 18px;
  border-radius: 16px;
  border: 1px solid #e2e8f0;
  font-size: 15px;
  outline: none;
  transition: 0.3s;
  background: #f8fafc;
}

.modern-modal input:focus,
.modern-modal select:focus {
  border-color: #2563eb;
  background: white;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

.input-group small {
  color: #64748b;
  font-size: 12px;
  margin-top: 6px;
  display: block;
}

/* SHIFT */

.shift-group {
  grid-column: span 2;
  display: flex;
  gap: 20px;
}

.shift-box {
  flex: 1;
}

.shift-box label {
  display: block;
  margin-bottom: 8px;
  font-size: 14px;
  color: #64748b;
}

.shift-box small {
  color: #64748b;
  font-size: 12px;
  margin-top: 6px;
  display: block;
}

/* BUTTONS */

.modal-actions {
  grid-column: span 2;
  display: flex;
  justify-content: flex-end;
  gap: 15px;
  margin-top: 20px;
}

.modal-actions button {
  border: none;
  padding: 14px 24px;
  border-radius: 16px;
  cursor: pointer;
  font-size: 15px;
  font-weight: 600;
  transition: 0.3s;
}

.modal-actions button[type="submit"] {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
}

.cancel-btn {
  background: #e2e8f0;
  color: #0f172a;
}

.modal-actions button:hover {
  transform: translateY(-2px);
}

/* Document Upload */

.document-section {
  grid-column: span 2;
  margin-top: 10px;
  justify-content: space-between;
  display: flex;
  padding: 20px;
}

.document-section h3 {
  margin-bottom: 15px;
  color: #111827;
  font-size: 18px;
}

/* BUTTON WRAPPER */

.doc-btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

/* DOCUMENT BUTTON */
.document-section h3 button {
  margin: 20px;
}

.upload-doc-btn {
  border: none;
  padding: 18px;
  border-radius: 14px;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  transition: 0.3s ease;
  white-space: nowrap;
  width: auto;
  flex: unset;
}

.upload-doc-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
}

.remove-doc-btn {
  width: 100%;
  margin-top: 12px;
  border: none;
  padding: 12px;
  border-radius: 12px;
  background: #ef4444;
  color: white;
  cursor: pointer;
  font-weight: 600;
}

.doc-preview-card {
  position: relative;
  overflow: hidden;
}

.doc-preview-card h4 {
  margin-bottom: 14px;
}

.documents-preview {
  margin-top: 15px;
}
/* DOCUMENT PREVIEW */

.documents-preview {
  grid-column: span 2;
  margin-top: 20px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 18px;
}

.doc-preview-card {
  background: #f8fafc;
  padding: 18px;
  border-radius: 20px;
  border: 1px solid #e2e8f0;
  transition: 0.3s ease;
}

.doc-preview-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.doc-preview-card h4 {
  margin-bottom: 14px;
  color: #0f172a;
  font-size: 16px;
}

.doc-preview-card input,
.doc-preview-card select {
  width: 100%;
  margin-top: 10px;
}

/* MOBILE */

@media (max-width: 768px) {
  .document-section {
    grid-column: span 1;
  }

  .documents-preview {
    grid-column: span 1;
    grid-template-columns: 1fr;
  }

  .doc-btn-group {
    flex-direction: column;
  }

  .upload-doc-btn {
    width: 100%;
  }
}

/* ANIMATION */

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40px) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

/* MOBILE */

@media (max-width: 768px) {
  .employee-modal {
    width: 100%;
    max-width: 100%;
    border-radius: 22px;
    padding: 20px;
  }

  .modern-modal {
    padding: 22px;
    border-radius: 24px;
  }

  .modern-modal form {
    grid-template-columns: 1fr;
  }

  .shift-group {
    grid-column: span 1;
    flex-direction: column;
  }

  .modal-actions {
    grid-column: span 1;
  }
}
