.attendance-page {
  padding: 30px;
  width: 100%;
  overflow-x: hidden;
}

.attendance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 30px;
}

.attendance-header h1 {
  font-size: 34px;

  color: #0f172a;
}

.attendance-header p {
  color: #64748b;
}

.attendance-header button {
  border: none;

  padding: 16px 20px;

  border-radius: 18px;

  background: linear-gradient(135deg, #2563eb, #4f46e5);

  color: white;

  cursor: pointer;
}

.attendance-grid {
  display: grid;

  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));

  gap: 24px;
}

.attendance-card {
  background: white;

  border-radius: 28px;

  padding: 28px;

  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.attendance-top {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 24px;
}

.attendance-icon {
  width: 58px;
  height: 58px;

  border-radius: 18px;

  background: #dbeafe;

  color: #2563eb;

  display: flex;
  justify-content: center;
  align-items: center;

  font-size: 24px;
}

.attendance-top button {
  border: none;

  width: 42px;
  height: 42px;

  border-radius: 12px;

  background: #fee2e2;

  color: #dc2626;

  cursor: pointer;
}

.attendance-date {
  display: inline-block;

  margin-top: 18px;

  padding: 8px 14px;

  border-radius: 30px;

  background: #ede9fe;

  color: #7c3aed;

  font-size: 13px;
}

.attendance-info {
  margin-top: 24px;

  display: grid;

  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));

  gap: 14px;
}

.attendance-info div {
  background: #f8fafc;

  padding: 16px;

  border-radius: 18px;
}

.attendance-info p {
  color: #64748b;

  font-size: 13px;
}

.attendance-info h4 {
  margin-top: 6px;

  color: #111827;
}

.attendance-status {
  display: inline-block;

  margin-top: 24px;

  padding: 10px 16px;

  border-radius: 30px;

  font-size: 13px;

  font-weight: 600;
}

.Present {
  background: #dcfce7;
  color: #15803d;
}

.Absent {
  background: #fee2e2;
  color: #dc2626;
}

.Half\ Day {
  background: #fef3c7;
  color: #d97706;
}

.attendance-actions {
  display: flex;
  gap: 10px;
}

.edit-btn,
.delete-btn {
  width: 40px;
  height: 40px;
  border: none;
  border-radius: 12px;
  color: white;
  cursor: pointer;
}

.edit-btn {
  background: #2563eb;
}

.delete-btn {
  background: #ef4444;
}

@media (max-width: 768px) {
  .attendance-page {
    padding: 20px;
  }

  .attendance-header {
    flex-direction: column;

    gap: 20px;

    align-items: flex-start;
  }

  .attendance-info {
    grid-template-columns: 1fr;
  }
}
