.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  padding: 20px;
  overflow-y: auto;
}

.leave-modal {
  width: 100%;
  max-width: 550px;
  max-height: 90vh;
  overflow-y: auto;
  background: white;
  border-radius: 28px;
  padding: 30px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

.leave-modal h2 {
  margin-bottom: 24px;
  color: #0f172a;
}

.leave-modal form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.leave-modal input,
.leave-modal select,
.leave-modal textarea {
  border: 1px solid #e2e8f0;
  padding: 16px;
  border-radius: 16px;
  outline: none;
  background: #f8fafc;
  font-size: 15px;
}

.leave-modal textarea {
  resize: none;
  min-height: 120px;
}

.leave-modal input:focus,
.leave-modal select:focus,
.leave-modal textarea:focus {
  border-color: #2563eb;
  background: white;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

.modal-actions {
  display: flex;
  gap: 14px;
  margin-top: 10px;
}

.modal-actions button {
  flex: 1;
  border: none;
  padding: 16px;
  border-radius: 16px;
  cursor: pointer;
  font-weight: 600;
  transition: 0.3s;
}

.modal-actions button[type="submit"] {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
}

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.modal-actions button:hover {
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .leave-modal {
    padding: 22px;
    border-radius: 22px;
  }

  .modal-actions {
    flex-direction: column;
  }
}