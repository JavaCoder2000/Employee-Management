/* BUTTONS */

.modal-actions {
  display: flex;

  gap: 14px;

  margin-top: 10px;
}

.modal-actions button {
  flex: 1;

  border: none;

  padding: 16px;

  border-radius: 16px;

  cursor: pointer;

  font-size: 15px;
  font-weight: 600;

  transition: 0.3s ease;
}

/* SAVE BUTTON */

.modal-actions button:first-child {
  background: linear-gradient(
    135deg,
    #2563eb,
    #4f46e5
  );

  color: white;
}

/* CANCEL BUTTON */

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.modal-actions button:hover {
  transform: translateY(-2px);
}