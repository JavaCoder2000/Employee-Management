.salary-page {
  padding: 20px;
}

.salary-header {
  margin-bottom: 30px;
}

.salary-header h1 {
  font-size: 34px;
  color: #0f172a;
}

.salary-header p {
  color: #64748b;
  margin-top: 6px;
}

.salary-grid {
  display: grid;

  grid-template-columns:
    repeat(auto-fit, minmax(320px,1fr));

  gap: 24px;
}

.salary-card {
  background: white;

  border-radius: 28px;

  padding: 28px;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.06);

  transition: 0.3s ease;
}

.salary-card:hover {
  transform: translateY(-6px);
}

.salary-month {
  display: inline-block;

  background: #dbeafe;

  color: #2563eb;

  padding: 8px 14px;

  border-radius: 30px;

  font-size: 14px;
  font-weight: 600;
}

.salary-card h2 {
  margin-top: 20px;

  font-size: 38px;

  color: #111827;
}

.salary-details {
  margin-top: 20px;

  display: flex;
  justify-content: space-between;
}

.salary-details p {
  color: #64748b;
  font-size: 13px;
}

.salary-details h4 {
  margin-top: 6px;
  color: #111827;
}

.salary-card button {
  width: 100%;

  margin-top: 24px;

  padding: 14px;

  border: none;

  border-radius: 16px;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  color: white;

  cursor: pointer;

  font-size: 15px;
  font-weight: 600;
}

.salary-table-wrapper {
  width: 100%;
  overflow-x: auto;
  margin-top: 20px;
}

.salary-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 20px;
  overflow: hidden;
}

.salary-table th {
  background: #2563eb;
  color: white;
  padding: 16px;
  text-align: left;
  font-size: 14px;
}

.salary-table td {
  padding: 16px;
  border-bottom: 1px solid #e2e8f0;
  font-size: 14px;
}

.salary-table tr:hover {
  background: #f8fafc;
}

.salary-status {
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}

.salary-status.Paid {
  background: #dcfce7;
  color: #166534;
}

.salary-status.Pending {
  background: #fef3c7;
  color: #92400e;
}

@media(max-width:768px) {

  .salary-page {
    margin-top: 25px;
  }

}