.notification-modal {
  width: 100%;
  max-width: 500px;

  background: white;

  border-radius: 28px;

  padding: 30px;

  margin: 20px;
}

.notification-modal h2 {
  margin-bottom: 24px;
}

.notification-modal form {
  display: flex;
  flex-direction: column;

  gap: 18px;
}

.notification-modal input,
.notification-modal textarea,
.notification-modal select {
  border:
    1px solid #e2e8f0;

  padding: 16px;

  border-radius: 16px;

  outline: none;
}

.notification-modal textarea {
  height: 120px;

  resize: none;
}

