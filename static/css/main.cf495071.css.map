.payroll-modal {
  width: 100%;
  max-width: 500px;

  background: white;

  border-radius: 28px;

  padding: 30px;

  margin: 20px;
}

.payroll-modal h2 {
  margin-bottom: 24px;
}

.payroll-modal form {
  display: flex;
  flex-direction: column;

  gap: 18px;
}

.payroll-modal input,
.payroll-modal select {
  border:
    1px solid #e2e8f0;

  padding: 16px;

  border-radius: 16px;

  outline: none;
}

.modal-actions {
  display: flex;

  gap: 14px;

  margin-top: 10px;
}

.modal-actions button {
  flex: 1;

  border: none;

  padding: 16px;

  border-radius: 16px;

  cursor: pointer;
}

.modal-actions button:first-child {
  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  color: white;
}

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.modal-overlay {
  position: fixed;
  inset: 0;

  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(6px);

  display: flex;
  justify-content: center;
  align-items: center;

  padding: 20px;
  z-index: 9999;

  overflow-y: auto;
}

/* MODAL */

.payroll-modal {
  width: 100%;
  max-width: 520px;

  background: white;

  border-radius: 30px;

  padding: 32px;

  margin: auto;

  max-height: 92vh;
  overflow-y: auto;

  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);

  animation: modalSlide 0.35s ease;
}

/* SCROLLBAR */

.payroll-modal::-webkit-scrollbar {
  width: 8px;
}

.payroll-modal::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 20px;
}

/* TITLE */

.payroll-modal h2 {
  margin-bottom: 24px;

  font-size: 30px;
  font-weight: 700;

  color: #0f172a;
}

/* FORM */

.payroll-modal form {
  display: flex;
  flex-direction: column;

  gap: 18px;
}

/* INPUTS */

.payroll-modal input,
.payroll-modal select {
  border: 1px solid #e2e8f0;

  padding: 16px 18px;

  border-radius: 16px;

  outline: none;

  font-size: 15px;

  background: #f8fafc;

  transition: 0.3s ease;
}

.payroll-modal input:focus,
.payroll-modal select:focus {
  border-color: #2563eb;

  background: white;

  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

/* BUTTONS */

.modal-actions {
  display: flex;

  gap: 14px;

  margin-top: 10px;
}

.modal-actions button {
  flex: 1;

  border: none;

  padding: 16px;

  border-radius: 16px;

  cursor: pointer;

  font-size: 15px;
  font-weight: 600;

  transition: 0.3s ease;
}

/* SAVE BUTTON */

.modal-actions button:first-child {
  background: linear-gradient(
    135deg,
    #2563eb,
    #4f46e5
  );

  color: white;
}

/* CANCEL BUTTON */

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.modal-actions button:hover {
  transform: translateY(-2px);
}

/* MOBILE */

@media (max-width: 768px) {
  .payroll-modal {
    padding: 22px;

    border-radius: 24px;

    max-height: 95vh;
  }

  .modal-actions {
    flex-direction: column;
  }

  .payroll-modal h2 {
    font-size: 24px;
  }
}

/* ANIMATION */

@keyframes modalSlide {
  from {
    opacity: 0;
    transform: translateY(40px) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}