.attendance-page {
  padding: 20px;
}

.attendance-header {
  margin-bottom: 30px;
}

.attendance-header h1 {
  font-size: 34px;
  color: #0f172a;
}

.attendance-header p {
  color: #64748b;
  margin-top: 6px;
}

.attendance-grid {
  display: grid;

  grid-template-columns:
    repeat(auto-fit, minmax(320px, 1fr));

  gap: 24px;
}

.attendance-card {
  background: white;

  border-radius: 26px;

  padding: 24px;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.06);

  transition: 0.3s ease;
}

.attendance-card:hover {
  transform: translateY(-6px);
}

.attendance-top {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 20px;
}

.attendance-top h3 {
  color: #111827;
}

.present {
  background: #dcfce7;
  color: #15803d;

  padding: 8px 14px;

  border-radius: 30px;

  font-size: 14px;
  font-weight: 600;
}

.absent {
  background: #fee2e2;
  color: #dc2626;

  padding: 8px 14px;

  border-radius: 30px;

  font-size: 14px;
  font-weight: 600;
}

.attendance-info {
  display: grid;

  grid-template-columns: repeat(3,1fr);

  gap: 16px;
}

.attendance-info p {
  color: #64748b;
  font-size: 13px;
}

.attendance-info h4 {
  margin-top: 6px;
  color: #111827;
}

.attendance-table-wrapper {
  width: 100%;
  overflow-x: auto;
  margin-top: 20px;
}

.attendance-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 20px;
  overflow: hidden;
}

.attendance-table th {
  background: #2563eb;
  color: white;
  padding: 16px;
  text-align: left;
  font-size: 14px;
  white-space: nowrap;
}

.attendance-table td {
  padding: 16px;
  border-bottom: 1px solid #e2e8f0;
  font-size: 14px;
  white-space: nowrap;
}

.attendance-table tr:hover {
  background: #f8fafc;
}

.attendance-status {
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}

.attendance-status.Present {
  background: #dcfce7;
  color: #166534;
}

.attendance-status.Absent {
  background: #fee2e2;
  color: #991b1b;
}

.attendance-status.Half\ Day {
  background: #fef3c7;
  color: #92400e;
}


@media(max-width:768px) {
  .attendance-info {
    grid-template-columns: 1fr;
  }

}