.leave-page {
  padding: 30px;
  min-height: 100vh;
  background: #f8fafc;
  overflow-x: hidden;
}

/* HEADER */

.leave-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}

.leave-header h1 {
  font-size: 34px;
  font-weight: 700;
  color: #0f172a;
}

.leave-header p {
  margin-top: 6px;
  color: #64748b;
  font-size: 15px;
}

/* ADD BUTTON */

.add-leave-btn {
  border: none;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
  padding: 14px 22px;
  border-radius: 16px;
  cursor: pointer;
  font-weight: 600;
  font-size: 14px;
  transition: 0.3s;
  box-shadow: 0 10px 25px rgba(37, 99, 235, 0.2);
}

.add-leave-btn:hover {
  transform: translateY(-2px);
}

/* TABLE */

.leave-table-wrapper {
  width: 100%;
  overflow-x: auto;
  border-radius: 24px;
  background: white;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
}

/* SCROLLBAR */

.leave-table-wrapper::-webkit-scrollbar {
  height: 8px;
}

.leave-table-wrapper::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 20px;
}

/* TABLE */

.leave-table {
  width: 100%;
  min-width: 950px;
  border-collapse: collapse;
}

.leave-table thead {
  background: #f1f5f9;
}

.leave-table th {
  padding: 18px;
  text-align: left;
  color: #334155;
  font-size: 14px;
  font-weight: 700;
  white-space: nowrap;
}

.leave-table td {
  padding: 18px;
  border-top: 1px solid #f1f5f9;
  color: #0f172a;
  font-size: 14px;
  white-space: nowrap;
}

.leave-table tbody tr {
  transition: 0.3s;
}

.leave-table tbody tr:hover {
  background: #f8fafc;
}

/* STATUS */

.leave-status {
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  display: inline-block;
}

.Pending {
  background: #fef3c7;
  color: #d97706;
}

.Approved {
  background: #dcfce7;
  color: #15803d;
}

.Rejected {
  background: #fee2e2;
  color: #dc2626;
}

/* ACTIONS */

.leave-actions {
  display: flex;
  gap: 10px;
}

/* EDIT BUTTON */

.edit-btn {
  border: none;
  background: #dbeafe;
  color: #2563eb;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  transition: 0.3s;
  font-size: 18px;
}

.edit-btn:hover {
  background: #2563eb;
  color: white;
  transform: translateY(-2px);
}

/* DELETE BUTTON */

.delete-btn {
  border: none;
  background: #fee2e2;
  color: #dc2626;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  transition: 0.3s;
  font-size: 18px;
}

.delete-btn:hover {
  background: #dc2626;
  color: white;
  transform: translateY(-2px);
}

/* EMPTY */

.no-leaves {
  background: white;
  border-radius: 28px;
  padding: 60px 20px;
  text-align: center;
}

.no-leaves h2 {
  margin-top: 14px;
  color: #0f172a;
}

.no-leaves p {
  margin-top: 8px;
  color: #64748b;
}

/* MOBILE */

@media (max-width: 768px) {
  .leave-page {
    padding: 20px;
  }

  .leave-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .leave-header h1 {
    font-size: 28px;
  }

  .leave-table {
    min-width: 850px;
  }

  .leave-table th,
  .leave-table td {
    padding: 14px;
    font-size: 13px;
  }

  .add-leave-btn {
    width: 100%;
    justify-content: center;
  }
}