.payroll-page {
  padding: 30px;
}

.payroll-header {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 30px;
}

.payroll-header h1 {
  font-size: 34px;

  color: #0f172a;
}

.payroll-header p {
  color: #64748b;
}

.payroll-header button {
  border: none;

  padding: 16px 20px;

  border-radius: 18px;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  color: white;

  cursor: pointer;
}

.payroll-grid {
  display: grid;

  grid-template-columns:
    repeat(auto-fit,minmax(340px,1fr));

  gap: 24px;
}

.payroll-card {
  background: white;

  border-radius: 28px;

  padding: 28px;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.05);
}

.payroll-top {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 24px;
}

.payroll-icon {
  width: 58px;
  height: 58px;

  border-radius: 18px;

  background: #dbeafe;

  color: #2563eb;

  display: flex;
  justify-content: center;
  align-items: center;

  font-size: 24px;
}

.payroll-top button {
  border: none;

  width: 42px;
  height: 42px;

  border-radius: 12px;

  background: #fee2e2;

  color: #dc2626;

  cursor: pointer;
}

.payroll-month {
  display: inline-block;

  margin-top: 18px;

  padding: 8px 14px;

  border-radius: 30px;

  background: #ede9fe;

  color: #7c3aed;

  font-size: 13px;
}

.salary-box {
  margin-top: 24px;

  display: grid;

  grid-template-columns:
    repeat(3,1fr);

  gap: 14px;
}

.salary-box div {
  background: #f8fafc;

  padding: 16px;

  border-radius: 18px;
}

.salary-box p {
  color: #64748b;

  font-size: 13px;
}

.salary-box h4 {
  margin-top: 6px;

  color: #111827;
}

.final-salary {
  margin-top: 24px;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #4f46e5
    );

  padding: 24px;

  border-radius: 24px;

  color: white;
}

.final-salary h1 {
  margin-top: 10px;

  font-size: 40px;
}

.salary-status {
  display: inline-block;

  margin-top: 24px;

  padding: 10px 16px;

  border-radius: 30px;

  font-size: 13px;

  font-weight: 600;
}

.Paid {
  background: #dcfce7;
  color: #15803d;
}

.Pending {
  background: #fef3c7;
  color: #d97706;
}

@media(max-width:768px) {

  .payroll-page {
    padding:
      90px 16px 20px;
  }

  .payroll-header {
    flex-direction: column;

    gap: 20px;

    align-items: flex-start;
  }

  .salary-box {
    grid-template-columns: 1fr;
  }

}