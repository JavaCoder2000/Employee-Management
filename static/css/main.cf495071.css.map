.employees-page {
  padding: 30px;
  width: 100%;
  overflow-x: hidden;
}

.employee-header {
  display: flex;
  justify-content: space-between;
  align-items: center;

  gap: 20px;

  margin-bottom: 30px;
}

.employee-header h1 {
  font-size: 34px;

  color: #0f172a;
}

.employee-header p {
  color: #64748b;
}

.search-box {
  flex: 1;

  display: flex;
  align-items: center;
  gap: 10px;

  background: white;

  padding: 16px 20px;

  border-radius: 18px;

  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
}

.search-box input {
  border: none;

  outline: none;

  width: 100%;
}

.employee-header button {
  border: none;

  padding: 16px 20px;

  border-radius: 18px;

  background: linear-gradient(135deg, #2563eb, #4f46e5);

  color: white;

  cursor: pointer;
}

.employee-grid {
  display: grid;

  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));

  gap: 24px;
}

.employee-card {
  background: white;

  border-radius: 28px;

  padding: 28px;

  text-align: center;

  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.employee-card img {
  width: 90px;
  height: 90px;

  border-radius: 50%;

  object-fit: cover;

  margin-bottom: 20px;
}

.employee-card p {
  color: #64748b;
}

.employee-info {
  display: flex;
  justify-content: center;
  gap: 10px;

  margin-top: 16px;
}

.employee-info span {
  padding: 8px 12px;

  border-radius: 30px;

  background: #dbeafe;

  color: #2563eb;

  font-size: 13px;
}

.employee-card h2 {
  margin-top: 20px;

  color: #0f172a;
}

.employee-actions {
  display: flex;
  justify-content: center;
  gap: 14px;

  margin-top: 24px;
}

.edit-btn,
.delete-btn {
  width: 46px;
  height: 46px;

  border: none;

  border-radius: 14px;

  cursor: pointer;
}

.edit-btn {
  background: #dbeafe;
  color: #2563eb;
}

.delete-btn {
  background: #fee2e2;
  color: #dc2626;
}

@media (max-width: 768px) {
  .employees-page {
    padding: 20px;
  }

  .employee-header {
    flex-direction: column;

    gap: 20px;

    align-items: flex-start;
  }

  .employee-header button {
    width: 100%;
  }
}
