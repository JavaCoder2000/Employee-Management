* {
  box-sizing: border-box;
}

body {
  margin: 0;
  overflow-x: hidden;

  background: #f1f5f9;

  font-family: Arial, sans-serif;
}

.layout {
  display: flex;
}

.page-content {
  margin-left: 280px;
  width: 100%;
  padding: 30px;
}


/* TOP COVER */
.profile-cover {
  height: 220px;
  background:
    linear-gradient(135deg, rgba(99, 102, 241, 0.95), rgba(37, 99, 235, 0.95)),
    url("https://images.unsplash.com/photo-1521737604893-d14cc237f11d");

  border-radius: 30px 30px 0 0;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 80px;
}

.profile-image-wrapper {
  position: absolute;
  bottom: -70px;
  left: 50%;
  transform: translateX(-50%);
}

.profile-image {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  object-fit: cover;
  border: 6px solid white;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.page-card p {
  color: #64748b;
  font-size: 14px;
  margin: 10px;
}

.info-grid,
.stats-grid,
.docs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px;
  align-items: center;
  justify-content: center;
}

.info-box,
.stat-box,
.doc-card {
  background: white;
  border-radius: 24px;
  padding: 26px;
  transition: 0.3s ease;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.04);
}

.info-box:hover,
.stat-box:hover,
.doc-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
}

.info-box p,
.stat-box p {
  color: #64748b;
  font-size: 14px;
}

.info-box h3,
.stat-box h2 {
  margin-top: 12px;
  color: #111827;
}

.stat-box h2 {
  font-size: 42px;
}

.doc-card button {
  margin-top: 18px;
  border: none;
  padding: 12px 18px;
  border-radius: 14px;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
  cursor: pointer;
  font-weight: 600;
}

.chat-box {
  position: fixed;
  right: 25px;
  bottom: 100px;
  width: 340px;
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
}

.chat-header {
  background: #2563eb;
  color: white;
  padding: 18px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
}

.chat-header button {
  background: none;
  border: none;
  color: white;
  font-size: 20px;
  cursor: pointer;
}

.chat-box textarea {
  width: 100%;
  height: 120px;
  border: none;
  padding: 18px;
  resize: none;
  outline: none;
}

.chat-float-btn {
  position: fixed;
  right: 25px;
  bottom: 25px;
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: none;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
  font-size: 30px;
  cursor: pointer;
  box-shadow: 0 15px 35px rgba(37, 99, 235, 0.4);
  transition: 0.3s ease;
}

.send-btn {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: white;
  border: none;
  padding: 12px 18px;
  border-radius: 14px;
  cursor: pointer;
}
.chat-float-btn:hover {
  transform: scale(1.08);
}


/* MOBILE */

@media (max-width: 768px) {
  .page-content {
    margin-left: 0;
    margin-top: 40px;
    padding: 10px 16px 20px;
  }

  h1 {
    font-size: 24px !important;
  }

  h2 {
    font-size: 20px !important;
  }

  .chat-float-btn {
    width: 58px;
    height: 58px;

    font-size: 22px;

    right: 18px;
    bottom: 18px;
  }
}